# ARQA Dashboard — Environment Variables
# Copy this file to .env and fill in the values.

# App environment: development | production
FLASK_ENV=development

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string

# PostgreSQL (optional — enables Postgres mode)
# DATABASE_URL=postgresql://localhost/arqa

# Google Sheets (optional — enables Sheets mode or Sheets sync)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_ID=your-spreadsheet-id-here

# For deploy (alternative to GOOGLE_CREDENTIALS_FILE):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
